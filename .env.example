# Copy to .env and fill in
#
# LLM (pick one — optional; no key = context-only RAG)
# LLM_PROVIDER=auto   # auto | groq | gemini | openai | context_only
#
# Free tiers (recommended for demos):
#   Groq:   https://console.groq.com/keys   → OpenAI-compatible, fast
#   Gemini: https://aistudio.google.com/apikey
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
# See https://ai.google.dev/gemini-api/docs/models/gemini (e.g. gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
#
# Paid:
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DATABASE_URL=sqlite:///./legal_advisor.db
# Comma-separated browser origins allowed to call the API (required for production).
# Local Vite default is 5173. On Render, add your Vercel URL, e.g.:
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RAG_TOP_K=5
